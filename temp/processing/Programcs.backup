using System;
using System.IO;
using System.Net;
using System.Text;
using System.Text.Json;
using System.Threading.Tasks;
using Topshelf;
using Serilog;

namespace RFID_Gateway
{
    class Program
    {
        static void Main(string[] args)
        {
            // Configurar logging
            Log.Logger = new LoggerConfiguration()
                .MinimumLevel.Information()
                .WriteTo.File("rfid_gateway.log", 
                    rollingInterval: RollingInterval.Day,
                    retainedFileCountLimit: 7,
                    outputTemplate: "{Timestamp:yyyy-MM-dd HH:mm:ss.fff} [{Level:u3}] {Message:lj}{NewLine}{Exception}")
                .CreateLogger();

            var rc = HostFactory.Run(x =>
            {
                x.Service<RFIDService>(s =>
                {
                    s.ConstructUsing(name => new RFIDService());
                    s.WhenStarted(tc => tc.Start());
                    s.WhenStopped(tc => tc.Stop());
                });
                x.RunAsLocalSystem();
                x.SetDescription("RFID Gateway para Condominio Neos Tech - Procesa tags y control de accesos");
                x.SetDisplayName("RFID Gateway Condominio");
                x.SetServiceName("RFIDGatewayCondominio");
                x.StartAutomatically();
                x.EnableServiceRecovery(r => r
                    .RestartService(1)
                    .RestartService(5)
                    .RestartService(10));
            });

            var exitCode = (int)Convert.ChangeType(rc, rc.GetTypeCode());
            Environment.ExitCode = exitCode;
        }
    }

    public class RFIDService
    {
        private HttpListener _listener;
        private readonly HttpClient _httpClient;
        private readonly string _cloudFunctionUrl = "https://us-central1-neos-tech.cloudfunctions.net/rfid-gateway";
        private bool _isRunning;

        public RFIDService()
        {
            _httpClient = new HttpClient();
            _httpClient.Timeout = TimeSpan.FromSeconds(30);
        }

        public void Start()
        {
            Log.Information("Iniciando RFID Gateway para Condominio...");
            
            try
            {
                // Iniciar listener HTTP en puerto 60000
                _listener = new HttpListener();
                _listener.Prefixes.Add("http://*:60000/");
                _listener.Start();
                
                _isRunning = true;
                
                // Iniciar hilo para manejar peticiones
                Task.Run(() => HandleRequests());
                
                Log.Information($"RFID Gateway iniciado. Escuchando en puerto 60000");
                Log.Information($"Cloud Function: {_cloudFunctionUrl}");
            }
            catch (Exception ex)
            {
                Log.Error(ex, "Error al iniciar el gateway");
                throw;
            }
        }

        public void Stop()
        {
            Log.Information("Deteniendo RFID Gateway...");
            _isRunning = false;
            _listener?.Stop();
            _listener?.Close();
            Log.Information("RFID Gateway detenido");
        }

        private async Task HandleRequests()
        {
            while (_isRunning)
            {
                try
                {
                    var context = await _listener.GetContextAsync();
                    _ = Task.Run(() => ProcessRequest(context));
                }
                catch (HttpListenerException ex) when (ex.ErrorCode == 995)
                {
                    // Error debido a que el listener fue cerrado
                    break;
                }
                catch (Exception ex)
                {
                    Log.Error(ex, "Error en el manejador de peticiones");
                }
            }
        }

        private async Task ProcessRequest(HttpListenerContext context)
        {
            HttpListenerRequest request = context.Request;
            HttpListenerResponse response = context.Response;

            try
            {
                Log.Information($"Nueva petición: {request.HttpMethod} {request.Url}");

                // Procesar según el método y ruta
                if (request.HttpMethod == "POST")
                {
                    if (request.Url.AbsolutePath == "/open-gate")
                    {
                        await HandleOpenGate(request, response);
                        return;
                    }
                    else if (request.Url.AbsolutePath == "/")
                    {
                        await HandleRFIDTag(request, response);
                        return;
                    }
                }
                else if (request.HttpMethod == "GET")
                {
                    if (request.Url.AbsolutePath == "/health")
                    {
                        await HandleHealthCheck(response);
                        return;
                    }
                    else if (request.Url.AbsolutePath == "/gate-status")
                    {
                        await HandleGateStatus(response);
                        return;
                    }
                    else if (request.Url.AbsolutePath == "/users")
                    {
                        await HandleGetUsers(response);
                        return;
                    }
                }

                // Si no coincide ninguna ruta conocida
                await SendResponse(response, 404, new { error = "Ruta no encontrada" });
            }
            catch (Exception ex)
            {
                Log.Error(ex, "Error procesando petición");
                await SendResponse(response, 500, new { error = "Error interno del servidor" });
            }
        }

        private async Task HandleRFIDTag(HttpListenerRequest request, HttpListenerResponse response)
        {
            // Leer cuerpo de la petición
            string requestBody;
            using (var reader = new StreamReader(request.InputStream, request.ContentEncoding))
            {
                requestBody = await reader.ReadToEndAsync();
            }

            Log.Information($"Datos recibidos: {requestBody}");

            // Parsear datos (formato del lector TY001)
            var tagData = ParseTagData(requestBody);
            if (tagData == null)
            {
                await SendResponse(response, 400, new { error = "Formato de datos inválido" });
                return;
            }

            // Enviar a Cloud Function
            var cloudResponse = await SendToCloudFunction(tagData);
            
            // Responder al lector
            await SendResponse(response, cloudResponse.StatusCode, cloudResponse.Data);
        }

        private async Task HandleOpenGate(HttpListenerRequest request, HttpListenerResponse response)
        {
            // Leer cuerpo de la petición
            string requestBody;
            using (var reader = new StreamReader(request.InputStream, request.ContentEncoding))
            {
                requestBody = await reader.ReadToEndAsync();
            }

            Log.Information($"Comando abrir portón: {requestBody}");

            // Parsear comando
            var command = JsonSerializer.Deserialize<OpenGateCommand>(requestBody);
            if (command == null)
            {
                await SendResponse(response, 400, new { error = "Comando inválido" });
                return;
            }

            // Enviar comando al controlador del portón (simulado)
            bool success = await SendToGateController(command);

            if (success)
            {
                Log.Information($"Portón {command.Destination} abierto por {command.User}");
                await SendResponse(response, 200, new { 
                    status = "success", 
                    message = $"Portón {command.Destination} abierto",
                    timestamp = DateTime.UtcNow
                });
            }
            else
            {
                await SendResponse(response, 500, new { 
                    status = "error", 
                    message = "Error al abrir portón" 
                });
            }
        }

        private async Task HandleHealthCheck(HttpListenerResponse response)
        {
            await SendResponse(response, 200, new { 
                status = "online",
                service = "RFID Gateway Condominio",
                version = "2.0",
                timestamp = DateTime.UtcNow,
                cloud_function = await CheckCloudFunctionHealth()
            });
        }

        private async Task HandleGateStatus(HttpListenerResponse response)
        {
            await SendResponse(response, 200, new { 
                status = "operational",
                last_open = DateTime.UtcNow.AddMinutes(-5),
                open_count_today = 42,
                alerts_today = 3,
                readers_online = 1
            });
        }

        private async Task HandleGetUsers(HttpListenerResponse response)
        {
            // Obtener usuarios desde Firestore (simulado)
            var users = new[]
            {
                new { id = "1", nombre = "Juan", apellido = "Perez", unidad = "A-101", tipo = "propietario" },
                new { id = "2", nombre = "Maria", apellido = "Gomez", unidad = "B-202", tipo = "arrendatario" }
            };

            await SendResponse(response, 200, new { users });
        }

        private TagData ParseTagData(string requestBody)
        {
            try
            {
                // Intentar parsear como JSON
                var jsonData = JsonSerializer.Deserialize<Dictionary<string, JsonElement>>(requestBody);
                
                if (jsonData != null)
                {
                    // Formato JSON (nuevo formato)
                    string epc = jsonData.ContainsKey("epc") ? jsonData["epc"].GetString() 
                                : jsonData.ContainsKey("id") ? jsonData["id"].GetString() : null;
                    
                    string readerSn = jsonData.ContainsKey("reader_sn") ? jsonData["reader_sn"].GetString()
                                    : jsonData.ContainsKey("readsn") ? jsonData["readsn"].GetString() : null;

                    if (string.IsNullOrEmpty(epc) || string.IsNullOrEmpty(readerSn))
                        return null;

                    return new TagData
                    {
                        EPC = epc,
                        ReaderSN = readerSn,
                        Timestamp = jsonData.ContainsKey("timestamp") ? jsonData["timestamp"].GetString() 
                                    : DateTime.UtcNow.ToString("yyyy-MM-dd HH:mm:ss"),
                        GatewayVersion = jsonData.ContainsKey("gateway_version") ? jsonData["gateway_version"].GetString() : "2.0"
                    };
                }
            }
            catch
            {
                // Si falla JSON, intentar formato query string
                try
                {
                    var queryParams = System.Web.HttpUtility.ParseQueryString(requestBody);
                    
                    string epc = queryParams["id"];
                    string readerSn = queryParams["readsn"];
                    
                    if (string.IsNullOrEmpty(epc) || string.IsNullOrEmpty(readerSn))
                        return null;

                    return new TagData
                    {
                        EPC = epc,
                        ReaderSN = readerSn,
                        Timestamp = queryParams["timestamp"] ?? DateTime.UtcNow.ToString("yyyy-MM-dd HH:mm:ss"),
                        GatewayVersion = queryParams["gateway_version"] ?? "2.0"
                    };
                }
                catch
                {
                    return null;
                }
            }
            
            return null;
        }

        private async Task<(int StatusCode, object Data)> SendToCloudFunction(TagData tagData)
        {
            try
            {
                var payload = new {
                    tag_id = tagId,
                    reader_id = readerId,
                    timestamp = DateTime.UtcNow,
                    client_id = ConfigurationManager.AppSettings["ClientId"] // ← NUEVO
                };

                var jsonPayload = JsonSerializer.Serialize(payload);
                var content = new StringContent(jsonPayload, Encoding.UTF8, "application/json");

                Log.Information($"Enviando a Cloud Function: {jsonPayload}");

                var httpResponse = await _httpClient.PostAsync(_cloudFunctionUrl, content);
                var responseBody = await httpResponse.Content.ReadAsStringAsync();

                Log.Information($"Respuesta Cloud Function ({httpResponse.StatusCode}): {responseBody}");

                object responseData;
                try
                {
                    responseData = JsonSerializer.Deserialize<object>(responseBody);
                }
                catch
                {
                    responseData = responseBody;
                }

                return ((int)httpResponse.StatusCode, responseData);
            }
            catch (Exception ex)
            {
                Log.Error(ex, "Error enviando a Cloud Function");
                return (500, new { error = "Error de conexión con la nube", details = ex.Message });
            }
        }

        private async Task<bool> SendToGateController(OpenGateCommand command)
        {
            try
            {
                // Simular envío al controlador del portón
                // En producción, reemplazar con código real para controlar el hardware
                Log.Information($"Enviando comando al controlador: {command.Destination} por {command.Duration} segundos");

                // Simular retardo de comunicación
                await Task.Delay(500);

                // Simular éxito
                return true;
            }
            catch (Exception ex)
            {
                Log.Error(ex, "Error enviando comando al controlador");
                return false;
            }
        }

        private async Task<object> CheckCloudFunctionHealth()
        {
            try
            {
                var testData = new { epc = "health_check", reader_sn = "HEALTH_CHECK", timestamp = DateTime.UtcNow.ToString("yyyy-MM-dd HH:mm:ss") };
                var content = new StringContent(JsonSerializer.Serialize(testData), Encoding.UTF8, "application/json");
                
                var response = await _httpClient.PostAsync(_cloudFunctionUrl, content);
                return new { status = response.StatusCode, online = response.IsSuccessStatusCode };
            }
            catch
            {
                return new { status = 0, online = false };
            }
        }

        private async Task SendResponse(HttpListenerResponse response, int statusCode, object data)
        {
            response.StatusCode = statusCode;
            response.ContentType = "application/json";
            
            var jsonResponse = JsonSerializer.Serialize(data, new JsonSerializerOptions { WriteIndented = true });
            var buffer = Encoding.UTF8.GetBytes(jsonResponse);
            
            response.ContentLength64 = buffer.Length;
            await response.OutputStream.WriteAsync(buffer, 0, buffer.Length);
            response.OutputStream.Close();
        }
    }

    // Modelos de datos
    public class TagData
    {
        public string EPC { get; set; }
        public string ReaderSN { get; set; }
        public string Timestamp { get; set; }
        public string GatewayVersion { get; set; }
    }

    public class OpenGateCommand
    {
        public string Destination { get; set; } = "porton_principal";
        public int Duration { get; set; } = 10; // segundos
        public string User { get; set; } = "admin";
    }
}