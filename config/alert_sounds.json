  "generation_guidelines": {
    "description": "Guía para generar/obtener archivos de audio",
    "requirements": [
      "NUNCA usar sonidos oficiales de SHOA (ilegal)",
      "Crear sonidos personalizados o usar bibliotecas libres de derechos",
      "Frecuencias entre 300-1200Hz (rango audible claro)",
      "Duración 3-15 segundos máximo",
      "Volumen normalizado (-3dB peak)",
      "Formato MP3 128kbps mono",
      "Comprimir para optimizar descarga móvil"
    ],
    "sources": [
      "Freesound.org (licencia Creative Commons)",
      "Zapsplat.com (free sounds)",
      "Generadores de tono online (ToneGenerator.net)",
      "Audacity (software gratuito para crear tonos)",
      "GarageBand/FL Studio (DAWs profesionales)"
    ],
    "creation_steps": [
      "1. Abrir Audacity o generador de tonos",
      "2. Crear patrón según especificación (ej: 3 beeps 800Hz)",
      "3. Normalizar audio a -3dB",
      "4. Exportar como MP3 mono 128kbps",
      "5. Probar en dispositivo móvil",
      "6. Ajustar duración/volumen si es necesario",
      "7. Subir a Firebase Storage con script"
    ]
  },
  "legal_disclaimer": {
    "warning": "IMPORTANTE - CUMPLIMIENTO LEGAL",
    "points": [
      "❌ NO usar sonidos oficiales de SHOA (Servicio Hidrográfico y Oceanográfico de la Armada)",
      "❌ NO usar sonidos de Onemi (Oficina Nacional de Emergencia)",
      "❌ NO usar tonos de bomberos o ambulancias oficiales",
