<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <appSettings>
    <!-- Configuración de producción -->
    <add key="CloudFunctionUrl" value="https://us-central1-neos-tech.cloudfunctions.net/rfid-gateway-prod"/>
    <add key="GatewayId" value="NEOS-GATEWAY-001"/>
    <add key="GatewayVersion" value="condominio_2.0"/>
    <add key="MaxRetries" value="3"/>
    <add key="RetryDelayMs" value="1000"/>
    <add key="HealthCheckPort" value="60000"/>
    <add key="LogLevel" value="Information"/>
    
    <!-- Configuración de redis (si se necesita) -->
    <add key="CacheEnabled" value="true"/>
    <add key="CacheDurationMinutes" value="5"/>
    
    <!-- Seguridad -->
    <add key="ApiKey" value="PROD-API-KEY-CHANGE-ME"/>
    <add key="EnableEncryption" value="true"/>
  </appSettings>
  
  <system.diagnostics>
    <sources>
      <source name="RFIDGateway" switchName="sourceSwitch" switchType="System.Diagnostics.SourceSwitch">
        <listeners>
          <add name="console" type="System.Diagnostics.ConsoleTraceListener"/>
          <add name="logFile" type="System.Diagnostics.TextWriterTraceListener" initializeData="C:\Logs\RFIDGateway\gateway.log"/>
          <add name="eventLog" type="System.Diagnostics.EventLogTraceListener" initializeData="RFIDGateway"/>
        </listeners>
      </source>
    </sources>
    <switches>
      <add name="sourceSwitch" value="Information"/>
    </switches>
    <trace autoflush="true"/>
  </system.diagnostics>
  
  <runtime>
    <assemblyBinding xmlns="urn:schemas-microsoft-com:asm.v1">
      <dependentAssembly>
        <assemblyIdentity name="Newtonsoft.Json" publicKeyToken="30ad4fe6b2a6aeed" culture="neutral"/>
        <bindingRedirect oldVersion="0.0.0.0-13.0.0.0" newVersion="13.0.0.0"/>
      </dependentAssembly>
    </assemblyBinding>
  </runtime>
</configuration>
