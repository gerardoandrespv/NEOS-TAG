<?xml version="1.0" encoding="utf-8"?>
<configuration>
    <startup>
        <supportedRuntime version="v4.0" sku=".NETFramework,Version=v4.8"/>
    </startup>
    <appSettings>
        <!-- CONFIGURACIÓN MULTI-TENANT (OBLIGATORIO) -->
        <add key="ClientId" value="condominio-neos"/>
        <add key="ClientName" value="Condominio Neos Tech"/>
        
        <!-- CLOUD FUNCTION (OBLIGATORIO) -->
        <add key="CloudFunctionUrl" value="https://us-central1-neos-tech.cloudfunctions.net/rfid-gateway"/>
        
        <!-- CONFIGURACIÓN RFID -->
        <add key="ReaderIp" value="192.168.31.200"/>
        <add key="GatewayPort" value="60000"/>
        
        <!-- LOGGING -->
        <add key="LogLevel" value="Information"/>
        <add key="LogPath" value="C:\RFID_NeosTech_Condominio\rfid_gateway.log"/>
        
        <!-- TIMEOUTS -->
        <add key="HttpTimeout" value="30"/>
        <add key="MaxRetries" value="3"/>
    </appSettings>
</configuration>
